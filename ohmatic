#!/usr/bin/env bash
# ohmatic - one-command local launcher (Linux / macOS / Git Bash).
#
#   ./ohmatic start            Full stack: Python backend stubs + frontend (server mode).
#   ./ohmatic start --docker   Backend via docker compose instead of Python stubs.
#   ./ohmatic stop             Stop everything ohmatic started.
#   ./ohmatic status           Show what is running.
#   ./ohmatic doctor           Diagnose the system (Node, Python, Docker, ports).
#
# Dead-simple path after a fresh clone:  ./ohmatic start  -> open the printed URL.
# Requires: Node.js + npm (frontend), Python 3 (backend stubs). Docker only for --docker.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRONTEND="$ROOT/frontend"
RUN_DIR="$ROOT/.ohmatic-run"
HOST="127.0.0.1"
FRONTEND_PORT="${OHMATIC_FRONTEND_PORT:-5173}"

# name:dir:port  - the frontend only needs the gateway on :8080; the rest mirror topology.
SERVICES=(
  "gateway:$ROOT/gateway/stub:8080"
  "inference:$ROOT/inference/stub:8001"
  "verifier:$ROOT/verifier/stub:8002"
  "exporter:$ROOT/exporter/stub:8004"
)

# colours (disabled when not a TTY)
if [ -t 1 ]; then C_CYAN=$'\033[36m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_DIM=$'\033[90m'; C_OFF=$'\033[0m'
else C_CYAN=""; C_GREEN=""; C_YELLOW=""; C_RED=""; C_DIM=""; C_OFF=""; fi
# Circuit glyphs: ▸ signal in, ● lit pad / exit 0, ▲ amber, ✕ blown, · not energised.
step() { printf "%s▸ %s%s\n" "$C_CYAN" "$1" "$C_OFF"; }
ok()   { printf "  %s●%s  %s\n" "$C_GREEN" "$C_OFF" "$1"; }
warn() { printf "  %s▲%s  %s\n" "$C_YELLOW" "$C_OFF" "$1"; }
fail() { printf "  %s✕%s  %s\n" "$C_RED" "$C_OFF" "$1"; }
dim()  { printf "  %s·  %s%s\n" "$C_DIM" "$1" "$C_OFF"; }

# Masthead: the product pipeline as a PCB trace, lit pads at each stage and the
# signal flowing left to right. Same rail the frontend animates during a job.
banner() {
  printf "\n  %sΩ%s ohmatic    %sa compiler for circuits%s\n" "$C_GREEN" "$C_OFF" "$C_DIM" "$C_OFF"
  printf "  %s●%s" "$C_GREEN" "$C_OFF"
  local s
  for s in normalize generate verify deliver; do
    printf "━━ %s ━━%s●%s" "$s" "$C_GREEN" "$C_OFF"
  done
  printf " %s▸%s\n\n" "$C_GREEN" "$C_OFF"
}

# --- helpers ---------------------------------------------------------------

# A python on PATH may be broken (missing stdlib); probe before trusting it.
python_works() { "$@" -c "import sys" >/dev/null 2>&1; }

PYTHON=()
detect_python() {
  PYTHON=()
  local c
  for c in python3 python; do
    if command -v "$c" >/dev/null 2>&1 && python_works "$c"; then PYTHON=("$c"); return 0; fi
  done
  for c in "$HOME/miniconda3/bin/python" "$HOME/anaconda3/bin/python" \
           "$HOME/miniconda3/python.exe" "$HOME/anaconda3/python.exe"; do
    if [ -x "$c" ] && python_works "$c"; then PYTHON=("$c"); return 0; fi
  done
  return 1
}

npm_bin() { command -v npm 2>/dev/null || command -v npm.cmd 2>/dev/null || true; }

port_free() { # $1 host $2 port -> 0 free, 1 in use
  if (exec 3<>"/dev/tcp/$1/$2") 2>/dev/null; then exec 3>&- 3<&-; return 1; fi
  return 0
}

find_port() { # $1 host $2 start -> echoes a free port
  local p="$2"
  for _ in $(seq 1 20); do
    if port_free "$1" "$p"; then echo "$p"; return 0; fi
    p=$((p + 1))
  done
  echo "ERROR: no free port from $2" >&2; return 1
}

http_ok() { curl -fsS -m 2 "$1" >/dev/null 2>&1; }

# Open a URL in the default browser, cross-platform. Best-effort; never fails the run.
open_url() {
  local url="$1"
  if   command -v cmd.exe   >/dev/null 2>&1; then cmd.exe /c start "" "$url" >/dev/null 2>&1 || true   # Git Bash / WSL
  elif command -v xdg-open  >/dev/null 2>&1; then xdg-open "$url" >/dev/null 2>&1 || true               # Linux
  elif command -v open      >/dev/null 2>&1; then open "$url"     >/dev/null 2>&1 || true               # macOS
  else dim "open $url in your browser"; fi
}

save_pid() { mkdir -p "$RUN_DIR"; echo "$2" > "$RUN_DIR/$1.pid"; }

kill_tree() {
  local pid="$1" child
  if command -v pgrep >/dev/null 2>&1; then
    for child in $(pgrep -P "$pid" 2>/dev/null || true); do kill_tree "$child"; done
  fi
  kill "$pid" 2>/dev/null || true
}

# Best-effort: free a port regardless of how the process was launched. Covers the
# Git Bash case where $! is an MSYS pid that does not map to the native listener.
kill_port() {
  local port="$1" pid
  if command -v lsof >/dev/null 2>&1; then
    for pid in $(lsof -ti "tcp:$port" 2>/dev/null || true); do kill "$pid" 2>/dev/null || true; done
  elif command -v fuser >/dev/null 2>&1; then
    fuser -k "$port/tcp" >/dev/null 2>&1 || true
  elif command -v netstat >/dev/null 2>&1 && command -v taskkill >/dev/null 2>&1; then
    # Git Bash / Windows: map the listening port to its native PID and kill it.
    for pid in $(netstat -ano 2>/dev/null | grep -E "[:.]$port[[:space:]].*LISTENING" | awk '{print $NF}' | sort -u); do
      taskkill //PID "$pid" //F >/dev/null 2>&1 || true
    done
  fi
}

# A live instance on the port serves STALE code (it predates any git pull):
# kill it and start fresh. This is what made `ohmatic update` look like a no-op.
stop_stale_service() { # $1 name $2 port
  local name="$1" port="$2" pid i
  pid="$(cat "$RUN_DIR/$name.pid" 2>/dev/null || true)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then kill_tree "$pid"; fi
  if ! port_free "$HOST" "$port"; then kill_port "$port"; fi
  for i in $(seq 1 10); do
    if port_free "$HOST" "$port"; then return 0; fi
    sleep 0.3
  done
  warn "$name: :$port is still busy after the stop attempt"
  return 0
}

# --- backend ---------------------------------------------------------------

start_backend_stubs() {
  if ! detect_python; then
    echo "Python 3 not found or broken. Install Python 3 or use './ohmatic start --docker'." >&2
    exit 1
  fi
  mkdir -p "$RUN_DIR"
  local svc name dir port
  for svc in "${SERVICES[@]}"; do
    name="${svc%%:*}"; dir="$(echo "$svc" | cut -d: -f2)"; port="${svc##*:}"
    if [ ! -f "$dir/server.py" ]; then warn "$name: server.py missing, skipped"; continue; fi
    if ! port_free "$HOST" "$port"; then
      warn "$name: replacing the running instance on :$port (it serves pre-update code)"
      stop_stale_service "$name" "$port"
    fi
    ( cd "$dir" && nohup "${PYTHON[@]}" server.py >"$RUN_DIR/$name.log" 2>&1 & echo $! > "$RUN_DIR/$name.pid" )
    ok "$name -> http://$HOST:$port  (pid $(cat "$RUN_DIR/$name.pid"))"
  done
}

start_backend_docker() {
  command -v docker >/dev/null 2>&1 || { echo "docker not found. Drop --docker to use Python stubs." >&2; exit 1; }
  step "Starting backend via docker compose"
  ( cd "$ROOT" && docker compose up -d )
}

wait_for_gateway() {
  step "Waiting for gateway http://$HOST:8080/health"
  local i
  for i in $(seq 1 30); do
    if http_ok "http://$HOST:8080/health"; then ok "gateway healthy"; return 0; fi
    sleep 0.5
  done
  warn "gateway did not answer /health in time (check .ohmatic-run/gateway.log)"
  return 0
}

# --- frontend --------------------------------------------------------------

ensure_frontend_deps() {
  [ -f "$FRONTEND/package.json" ] || { echo "frontend/package.json not found under $ROOT" >&2; exit 1; }
  local npm; npm="$(npm_bin)"
  [ -n "$npm" ] || { echo "npm not found. Install Node.js (https://nodejs.org)." >&2; exit 1; }
  # install when missing OR stale (package.json newer than the last install)
  if [ ! -d "$FRONTEND/node_modules" ] || [ "$FRONTEND/package.json" -nt "$FRONTEND/node_modules/.package-lock.json" ]; then
    step "Installing frontend dependencies"
    ( cd "$FRONTEND" && "$npm" install )
  fi
}

start_frontend() {
  ensure_frontend_deps
  local npm; npm="$(npm_bin)"
  # An old vite on the port keeps serving the old bundle to the open tab while a
  # new one lands on port+1: replace it so the URL is stable and always current.
  if ! port_free "$HOST" "$FRONTEND_PORT"; then
    warn "frontend: replacing the running instance on :$FRONTEND_PORT"
    stop_stale_service "frontend" "$FRONTEND_PORT"
  fi
  local port; port="$(find_port "$HOST" "$FRONTEND_PORT")"
  step "Frontend: server mode (proxying /v1 + /health -> gateway :8080)"
  mkdir -p "$RUN_DIR"
  ( cd "$FRONTEND" && nohup "$npm" run dev -- --host "$HOST" --port "$port" >"$RUN_DIR/frontend.log" 2>&1 & echo $! > "$RUN_DIR/frontend.pid" )
  FRONTEND_URL="http://$HOST:$port"
  ok "frontend -> $FRONTEND_URL  (pid $(cat "$RUN_DIR/frontend.pid"))"
}

# --- commands --------------------------------------------------------------

cmd_start() {
  local mode="server" backend="stubs"
  for a in "$@"; do case "$a" in
    --docker) backend="docker" ;;
  esac; done
  banner
  step "Ohmatic starting"
  # anaconda MKL and pip torch both ship libiomp; without this the worker dies (OMP #15)
  export KMP_DUPLICATE_LIB_OK=TRUE
  hw_assess
  dim "doctor: model tier '${OHMATIC_TIER}' (${OHMATIC_TIER_WHY})"
  offer_deps_install
  # First run: onboard (scan + offer the matching model) and auto-open the app at
  # the end. Marker lives in the ephemeral run dir so a fresh clone re-onboards.
  local _marker="$RUN_DIR/.onboarded" _first=0
  [ -f "$_marker" ] || _first=1
  if [ "$_first" = 1 ]; then cmd_onboarding; mkdir -p "$RUN_DIR"; date -u +%Y-%m-%dT%H:%M:%SZ > "$_marker"; fi
  if [ "$backend" = "docker" ]; then start_backend_docker; else step "Starting Python backend stubs"; start_backend_stubs; fi
  wait_for_gateway
  start_frontend
  echo
  printf "%sOhmatic is up:%s\n" "$C_GREEN" "$C_OFF"
  echo "  Frontend : $FRONTEND_URL"
  echo "  Gateway  : http://$HOST:8080"
  echo "  Stop     : ./ohmatic stop"
  echo "  Logs     : .ohmatic-run/*.log"
  printf "\n  %sCompiles clean, or it doesn't ship.%s\n" "$C_DIM" "$C_OFF"
  # First run opens the app for you; later starts just print the URL.
  if [ "$_first" = 1 ] && [ -t 1 ]; then step "Opening Ohmatic in your browser"; open_url "$FRONTEND_URL"; fi
}

cmd_stop() {
  step "Stopping ohmatic"
  if [ -d "$RUN_DIR" ]; then
    local f name pid
    for f in "$RUN_DIR"/*.pid; do
      [ -e "$f" ] || continue
      name="$(basename "$f" .pid)"; pid="$(cat "$f" 2>/dev/null || true)"
      if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then kill_tree "$pid"; ok "stopped $name (pid $pid)"; else warn "$name was not running"; fi
      rm -f "$f"
    done
  fi
  # Fallback sweep: ensure the known backend ports and the frontend port are free.
  local svc port
  for svc in "${SERVICES[@]}"; do port="${svc##*:}"; if ! port_free "$HOST" "$port"; then kill_port "$port"; fi; done
  if ! port_free "$HOST" "$FRONTEND_PORT"; then kill_port "$FRONTEND_PORT"; fi
  if command -v docker >/dev/null 2>&1; then ( cd "$ROOT" && docker compose down >/dev/null 2>&1 || true ); fi
  ok "done"
}

cmd_status() {
  step "Ohmatic status"
  local svc name port
  for svc in "${SERVICES[@]}"; do
    name="${svc%%:*}"; port="${svc##*:}"
    if http_ok "http://$HOST:$port/health"; then ok "$(printf '%-10s' "$name") listening on :$port"; else dim "$(printf '%-10s' "$name") not running (:$port)"; fi
  done
  if [ -f "$RUN_DIR/frontend.pid" ] && kill -0 "$(cat "$RUN_DIR/frontend.pid")" 2>/dev/null; then
    ok "frontend   running (pid $(cat "$RUN_DIR/frontend.pid"))"
  else dim "frontend   not running"; fi
}



cmd_stats() {
  step "Ohmatic stats"
  if detect_python; then "${PYTHON[@]}" tools/stats.py; else fail "needs Python 3"; fi
}

cmd_update() {
  step "Ohmatic update - syncing this clone to the latest GitHub main"
  command -v git >/dev/null 2>&1 || { fail "git not found - install Git, then re-run './ohmatic update'"; return 1; }
  git -C "$ROOT" rev-parse --git-dir >/dev/null 2>&1 || { fail "not a git checkout - clone with 'git clone' to use update"; return 1; }
  # Hard reset to origin/main: this clone tracks the published main, not your
  # working copy. Local commits and tracked edits here are discarded (untracked
  # files survive). Meant for a consumer clone, NOT a dev checkout with WIP.
  if ! git -C "$ROOT" diff --quiet 2>/dev/null || ! git -C "$ROOT" diff --cached --quiet 2>/dev/null; then
    warn "local changes will be discarded (hard reset to origin/main)"
  fi
  git -C "$ROOT" fetch origin || { fail "fetch failed - check network/remote"; return 1; }
  local before after; before="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null)"
  git -C "$ROOT" reset --hard origin/main || { fail "reset failed - is 'main' on origin? (git status)"; return 1; }
  after="$(git -C "$ROOT" rev-parse --short HEAD 2>/dev/null)"
  if [ "$before" = "$after" ]; then
    ok "already current at $after"
  else
    ok "reset $before -> $after (origin/main)"
    if git -C "$ROOT" diff --name-only "$before" "$after" 2>/dev/null | grep -q "frontend/package.json"; then
      step "frontend dependencies changed - reinstalling"
      local npm; npm="$(npm_bin)"
      [ -n "$npm" ] && (cd "$ROOT/frontend" && "$npm" install)
    fi
  fi
  ok "done. Restart with: ./ohmatic stop && ./ohmatic start"
}

# Python packages the real pipeline needs, probed per tier. Module -> pip spec
# differs for torch (CPU vs CUDA index) and llama.cpp (prebuilt wheels).
deps_missing() {
  local tier="$1"
  [ "$tier" = "stub" ] && return 0
  local mods="huggingface_hub torch transformers sentencepiece accelerate" m
  case "$tier" in q4_k_m|q4_k_m_cpu|q8_0) mods="$mods llama_cpp" ;; esac
  for m in $mods; do
    "${PYTHON[@]}" -c "import $m" >/dev/null 2>&1 || printf "%s " "$m"
  done
}

pip_install_dep() {
  case "$1" in
    torch)
      if [ "${OHMATIC_VRAM_MB:-0}" -gt 0 ]; then "${PYTHON[@]}" -m pip install torch
      else "${PYTHON[@]}" -m pip install torch --index-url https://download.pytorch.org/whl/cpu; fi ;;
    llama_cpp)
      "${PYTHON[@]}" -m pip install llama-cpp-python --prefer-binary         --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cpu ;;
    *) "${PYTHON[@]}" -m pip install "$1" ;;
  esac
}

offer_deps_install() {
  detect_python || return 0
  local missing; missing="$(deps_missing "$OHMATIC_TIER")"
  [ -z "${missing// /}" ] && return 0
  warn "packages missing for the real pipeline: $missing"
  if [ ! -t 0 ]; then dim "install later: ./ohmatic doctor"; return 0; fi
  printf "  Install via pip now? [Y/n]: "
  local a; read -r a || a="n"
  case "$a" in
    n|N) dim "skipped - run './ohmatic doctor' anytime" ;;
    *) local m; for m in $missing; do pip_install_dep "$m"; done; ok "packages installed" ;;
  esac
}

# First-run consumer onboarding: scan the machine, state the verdict in plain words,
# then offer the matching model with one Y/N. The recommended pull installs BOTH the
# generator tier and the T5 normalizer (fetch_model --with-t5). Skips if a model is
# already present; the prompt skips itself in non-interactive shells (CI). Standalone:
# ./ohmatic onboarding   (other tiers: ./ohmatic fetch bf16|q8_0|q4_k_m)
cmd_onboarding() {
  hw_assess
  if [ -f "$ROOT/models/active.json" ]; then
    local t; t="$(sed -n 's/.*"tier"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$ROOT/models/active.json" 2>/dev/null | head -1)"
    ok "A local model is already installed${t:+ (tier '$t')}. Skipping download."
    return 0
  fi
  local vram_part=""
  [ "${OHMATIC_VRAM_MB:-0}" -gt 0 ] 2>/dev/null && vram_part=" and ${OHMATIC_VRAM_MB} MB VRAM (${OHMATIC_GPU:-GPU})"
  printf "\n  Ohmatic doctor scanned your device and found %s GB RAM%s.\n" "${OHMATIC_RAM_GB}" "$vram_part"
  if [ "$OHMATIC_TIER" = "stub" ]; then
    warn "Not enough memory for a local model - Ohmatic runs in stub mode. You can still explore the full loop."
    return 0
  fi
  printf "  I suggest you install the '%s' model (generator + T5 normalizer) - %s.\n" "$OHMATIC_TIER" "$OHMATIC_TIER_WHY"
  if [ ! -t 0 ]; then dim "non-interactive shell - run './ohmatic onboarding' to install when ready"; return 0; fi
  printf "  Want to go ahead? [Y/N]: "
  local a; read -r a || a="n"
  case "$a" in
    n|N|no|No) dim "skipped - run './ohmatic onboarding' (or './ohmatic fetch') anytime" ;;
    *) cmd_fetch --tier "$OHMATIC_TIER" ;;
  esac
}

cmd_fetch() {
  step "Ohmatic fetch - downloading the doctor-recommended weights"
  hw_assess
  ok "tier: ${OHMATIC_TIER} (${OHMATIC_TIER_WHY})"
  if detect_python; then "${PYTHON[@]}" tools/fetch_model.py "$@"; else fail "needs Python 3"; fi
}

# Hardware assessment: RAM + NVIDIA VRAM -> which Ohmatic model this machine
# can run. Writes $RUN_DIR/doctor.json (served by the gateway at /v1/doctor).
# Probes are || true-guarded: under set -euo pipefail a failing probe (broken
# nvidia driver, locked-down powershell) degrades the verdict, never the launcher.
# ── Dynamic OS reserve (mirror of gateway/stub/server.py _os_reserve_mb) ───────
# Q4_K_M CPU committed peak in MB: weights ~4794 + KV(n_ctx=16384) 2304 + prefix
# cache 2048. The generation loop is ML-framework-free (prompts render in pure
# Python; T5 is a short-lived subprocess), so the ~43 MB process runtime fits in
# the reserve and the peak is exactly weights+KV+prefix - no transformers/torch term.
# The doctor recommends a q4 tier only when total RAM clears this peak PLUS a dynamic
# OS reserve (what the OS + other apps use now), identical to the gateway guard - so
# the doctor never recommends a tier the guard then refuses.
Q4_COMMITTED_MB=9146
OS_RESERVE_FLOOR_MB=768
OS_RESERVE_CAP_MB=3072
OS_RESERVE_FALLBACK_MB=2048

# Available RAM in MB (what a new allocation can use), empty if unknown. Sizes the
# OS reserve only - never gates the evictable, mmap'd weights (those use total RAM).
_avail_ram_mb() {
  case "$(uname -s 2>/dev/null || echo unknown)" in
    Linux)  awk '/^MemAvailable/{printf "%d", $2/1024}' /proc/meminfo 2>/dev/null ;;
    Darwin) vm_stat 2>/dev/null | awk '
              /page size of/ { for (i=1;i<=NF;i++) if ($i=="of") ps=$(i+1) }
              /^Pages free:/        { v=$NF; gsub(/\./,"",v); free=v }
              /^Pages inactive:/    { v=$NF; gsub(/\./,"",v); inact=v }
              /^Pages speculative:/ { v=$NF; gsub(/\./,"",v); spec=v }
              END { if (ps=="") ps=4096; if (free+inact+spec > 0) printf "%d", (free+inact+spec)*ps/1048576 }' ;;
    MINGW*|MSYS*|CYGWIN*) powershell -NoProfile -Command "[int]((Get-CimInstance Win32_OperatingSystem).FreePhysicalMemory/1024)" 2>/dev/null ;;
  esac
}

# clamp(total-avail, FLOOR, CAP); FALLBACK when avail is unknown/non-numeric.
_os_reserve_mb() {  # args: total_mb avail_mb
  local total="$1" avail="$2" used reserve
  case "$avail" in (*[!0-9]*|"") echo "$OS_RESERVE_FALLBACK_MB"; return ;; esac
  used=$(( total - avail ))
  if [ "$used" -lt 0 ]; then used=0; fi
  reserve="$used"
  if [ "$reserve" -lt "$OS_RESERVE_FLOOR_MB" ]; then reserve="$OS_RESERVE_FLOOR_MB"; fi
  if [ "$reserve" -gt "$OS_RESERVE_CAP_MB" ]; then reserve="$OS_RESERVE_CAP_MB"; fi
  echo "$reserve"
}

# Hidden test seam: "__hwprobe <total_mb>:<avail_mb>" -> "reserve=<n> q4_cpu=<yes|no>"
# so tests can assert the bash reserve math matches the Python guard. avail empty
# (e.g. "16000:") exercises the fallback.
_hwprobe() {
  local arg="${1:-}" total avail reserve fits=no
  total="${arg%%:*}"; avail="${arg#*:}"
  case "$total" in (*[!0-9]*|"") total=0 ;; esac
  reserve="$(_os_reserve_mb "$total" "$avail")"
  if [ "$total" -ge $(( Q4_COMMITTED_MB + reserve )) ]; then fits=yes; fi
  echo "reserve=${reserve} q4_cpu=${fits}"
}

hw_assess() {
  mkdir -p "$RUN_DIR"
  local ram_gb=0 ram_mb=0 vram_mb=0 gpu="" os arch avail_mb=""
  os="$(uname -s 2>/dev/null || echo unknown)"; arch="$(uname -m 2>/dev/null || echo unknown)"
  case "$os" in
    Linux)  ram_gb=$(awk '/MemTotal/{printf "%d", $2/1048576}' /proc/meminfo 2>/dev/null || true)
            ram_mb=$(awk '/MemTotal/{printf "%d", $2/1024}' /proc/meminfo 2>/dev/null || true) ;;
    Darwin) ram_gb=$(( $(sysctl -n hw.memsize 2>/dev/null || echo 0) / 1073741824 ))
            ram_mb=$(( $(sysctl -n hw.memsize 2>/dev/null || echo 0) / 1048576 )) ;;
    MINGW*|MSYS*|CYGWIN*) ram_gb=$(powershell -NoProfile -Command "[int]((Get-CimInstance Win32_ComputerSystem).TotalPhysicalMemory/1GB)" 2>/dev/null || true)
            ram_mb=$(powershell -NoProfile -Command "[int]((Get-CimInstance Win32_ComputerSystem).TotalPhysicalMemory/1MB)" 2>/dev/null || true) ;;
  esac
  avail_mb="$(_avail_ram_mb || true)"
  if command -v nvidia-smi >/dev/null 2>&1; then
    vram_mb=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 || true)
    gpu=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 || true)
  fi
  # Strip CR/space (powershell, csv padding) with unambiguous ANSI-C quoting,
  # then digits-or-zero (some GPUs report "[N/A]").
  ram_gb="${ram_gb//[$'
' ]/}"; vram_mb="${vram_mb//[$'
' ]/}"; gpu="${gpu//$'
'/}"
  case "$ram_gb"  in (*[!0-9]*|"") ram_gb=0  ;; esac
  case "$vram_mb" in (*[!0-9]*|"") vram_mb=0 ;; esac
  ram_mb="${ram_mb//[!0-9]/}"; case "$ram_mb" in ("") ram_mb=0 ;; esac
  avail_mb="${avail_mb//[!0-9]/}"  # digits, or empty -> OS-reserve fallback
  # Dynamic OS reserve + the Q4 committed peak = the real RAM the q4 tiers need,
  # identical to gateway/stub/server.py _ram_guard.
  local reserve_mb q4_need_mb
  reserve_mb="$(_os_reserve_mb "$ram_mb" "$avail_mb")"
  q4_need_mb=$(( Q4_COMMITTED_MB + reserve_mb ))
  local tier="stub" why="not enough RAM/VRAM for local inference - stub/cloud mode"
  if   [ "$vram_mb" -ge 20000 ]; then tier="bf16";       why="${gpu} (${vram_mb} MB VRAM) fits the full bf16 model"
  elif [ "$vram_mb" -ge 10000 ]; then tier="q8_0";       why="${gpu} (${vram_mb} MB VRAM) fits the Q8_0 GGUF"
  elif [ "$vram_mb" -ge  6000 ]; then tier="q4_k_m";     why="${gpu} (${vram_mb} MB VRAM) fits the Q4_K_M GGUF"
  elif [ "$os" = "Darwin" ] && [ "$arch" = "arm64" ] && [ "$ram_gb" -ge 24 ]; then
    tier="q8_0";   why="Apple Silicon, ${ram_gb} GB unified memory - Q8_0 GGUF on Metal"
  # q4 tiers: total RAM must clear the committed peak (weights+KV+prefix) plus the
  # DYNAMIC OS reserve - mirrors _ram_guard, so the doctor never recommends a tier
  # the guard then refuses. A lean box clears it near ~10 GB; a busy box needs more.
  elif [ "$os" = "Darwin" ] && [ "$arch" = "arm64" ] && [ "$ram_mb" -ge "$q4_need_mb" ]; then
    tier="q4_k_m"; why="Apple Silicon, ${ram_gb} GB unified memory - Q4_K_M GGUF on Metal"
  elif [ "$ram_mb" -ge "$q4_need_mb" ]; then
    tier="q4_k_m_cpu"; why="${ram_gb} GB RAM (~${reserve_mb} MB held for OS) runs Q4_K_M on CPU (slow)"
  fi
  printf '{"ram_gb": %s, "vram_mb": %s, "gpu": "%s", "recommended_model": "%s", "reason": "%s", "checked_at": "%s"}
'     "$ram_gb" "$vram_mb" "$gpu" "$tier" "$why" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$RUN_DIR/doctor.json"
  OHMATIC_TIER="$tier"; OHMATIC_TIER_WHY="$why"; OHMATIC_RAM_GB="$ram_gb"; OHMATIC_VRAM_MB="$vram_mb"; OHMATIC_GPU="$gpu"
}

cmd_doctor() {
  step "Ohmatic doctor"
  local ok_fe=1 ok_be=0
  printf "  %sos        %s, bash %s%s\n" "$C_DIM" "$(uname -s -m 2>/dev/null || echo unknown)" "${BASH_VERSION:-?}" "$C_OFF"

  if command -v node >/dev/null 2>&1; then ok "node      $(node --version)  ($(command -v node))"; else fail "node      not found - install Node.js 18+ (https://nodejs.org)"; ok_fe=0; fi
  local npm; npm="$(npm_bin)"
  if [ -n "$npm" ]; then ok "npm       $("$npm" --version)"; else fail "npm       not found - ships with Node.js"; ok_fe=0; fi

  if detect_python; then ok "python    $("${PYTHON[@]}" -c 'import sys;print(sys.version.split()[0])')  (${PYTHON[*]})"; ok_be=1
  else warn "python    no working interpreter found - backend needs Python 3 or Docker"; fi

  if command -v docker >/dev/null 2>&1; then ok "docker    $(docker --version)  (enables: ./ohmatic start --docker)"; ok_be=1
  else dim "docker    not found (optional - only needed for --docker)"; fi

  hw_assess
  if [ "$OHMATIC_VRAM_MB" -gt 0 ] 2>/dev/null; then ok "gpu       VRAM ${OHMATIC_VRAM_MB} MB"; else dim "gpu       no NVIDIA GPU detected (nvidia-smi absent)"; fi
  ok "ram       ${OHMATIC_RAM_GB} GB"
  ok "model     recommended: ${OHMATIC_TIER} - ${OHMATIC_TIER_WHY}"
  offer_deps_install

  local busy="" p
  for p in 8080 8001 8002 8004 "$FRONTEND_PORT"; do port_free "$HOST" "$p" || busy="$busy $p"; done
  if [ -z "$busy" ]; then ok "ports     8080 8001 8002 8004 $FRONTEND_PORT all free"; else warn "ports     in use:$busy (frontend port auto-advances)"; fi

  echo
  if [ "$ok_fe" = 1 ] && [ "$ok_be" = 1 ]; then printf "%sVerdict: ready. Run './ohmatic start'.%s\n" "$C_GREEN" "$C_OFF"
  elif [ "$ok_fe" = 1 ]; then printf "%sVerdict: frontend OK but no backend runtime. Run './ohmatic start --mock', or install Python 3 / Docker.%s\n" "$C_YELLOW" "$C_OFF"
  else printf "%sVerdict: install Node.js first, then re-run './ohmatic doctor'.%s\n" "$C_RED" "$C_OFF"; fi
}

usage() {
  banner
  cat <<'EOF'
  ./ohmatic start          Full stack: Python backend stubs + frontend (server mode)
  ./ohmatic start --docker Backend via docker compose instead of Python stubs
  ./ohmatic stop           Stop everything ohmatic started
  ./ohmatic status         Show what is running
  ./ohmatic doctor         Diagnose the system (Node, Python, ports, RAM/GPU -> model tier)
  ./ohmatic stats          Adoption stats (HF model downloads, GitHub stars)
  ./ohmatic onboarding     Scan hardware + install the matching model (auto on first start)
  ./ohmatic fetch          Download the doctor-recommended model weights (resumable)
  ./ohmatic update         Reset this clone to the latest GitHub main (discards local edits)

  Fresh clone -> './ohmatic start' -> open the printed URL.
EOF
}

case "${1:-help}" in
  start)  shift; cmd_start "$@" ;;
  stop)   cmd_stop ;;
  status) cmd_status ;;
  doctor) cmd_doctor ;;
  stats) cmd_stats ;;
  onboarding) cmd_onboarding ;;
  fetch) shift; cmd_fetch "$@" ;;
  update) cmd_update ;;
  __hwprobe) shift; _hwprobe "${1:-}" ;;  # hidden: reserve/tier math probe for tests
  help|--help|-h) usage ;;
  *) usage; exit 2 ;;
esac
