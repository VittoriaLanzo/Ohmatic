{"metadata":{"title":"24V to 3.3V resistive divider for MCU input","description":"62k/10k resistor divider scales 24V down to ~3.33V for an MCU input; divider current ~0.33mA (<1mA). Output exposed on connector J1.","version":"0.1","tags":["voltage-divider","24v","3v3","mcu","low-current"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"VCC1","type":"power_vcc","value":"24V","part":"PWR","pins":{"1":"VCC"}},{"id":"R1","type":"resistor","value":"62k","part":"0603","pins":{"1":"VCC","2":"DIV_OUT"}},{"id":"R2","type":"resistor","value":"10k","part":"0603","pins":{"1":"DIV_OUT","2":"GND"}},{"id":"J1","type":"connector","value":"MCU_ADC_IN","part":"HDR-1x2","pins":{"1":"DIV_OUT","2":"GND"}},{"id":"GND1","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}}],"nets":[{"name":"VCC","pins":["VCC1.1","R1.1"]},{"name":"DIV_OUT","pins":["R1.2","R2.1","J1.1"]},{"name":"GND","pins":["R2.2","J1.2","GND1.1"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"VCC1","x":20,"y":40},{"id":"R1","x":80,"y":40},{"id":"R2","x":140,"y":100},{"id":"J1","x":220,"y":40},{"id":"GND1","x":140,"y":160}]}}