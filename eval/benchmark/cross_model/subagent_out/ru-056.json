{"metadata":{"title":"Optocoupler digital signal isolator 3V3 to 5V","description":"PC817 optocoupler isolates a 3.3V logic signal; input LED driven through a 470R series resistor referenced to isolated ground, output phototransistor pulls a 10k pull-up to the 5V VCC rail low. Speed ~1k baud, well within PC817 bandwidth.","version":"0.1","tags":["optocoupler","isolation","level-shift","3v3","5v"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"J1","type":"connector","value":"INPUT_3V3","part":"1x03","pins":{"1":"3V3","2":"SIG_IN","3":"GND_ISO"}},{"id":"PWR1","type":"power_3v3","value":"3.3V","part":"PWR","pins":{"1":"3V3"}},{"id":"PWR2","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND_ISO"}},{"id":"R1","type":"resistor","value":"470","part":"0603","pins":{"1":"SIG_IN","2":"N_ANODE"}},{"id":"U1","type":"optocoupler","value":"PC817","part":"DIP-4","pins":{"A":"N_ANODE","K":"GND_ISO","C":"OUT_5V","E":"GND"}},{"id":"PWR3","type":"power_vcc","value":"5V","part":"PWR","pins":{"1":"VCC"}},{"id":"PWR4","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}},{"id":"R2","type":"resistor","value":"10k","part":"0603","pins":{"1":"VCC","2":"OUT_5V"}},{"id":"C1","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VCC","2":"GND"}},{"id":"J2","type":"connector","value":"OUTPUT_5V","part":"1x03","pins":{"1":"VCC","2":"OUT_5V","3":"GND"}}],"nets":[{"name":"3V3","pins":["J1.1","PWR1.1"]},{"name":"SIG_IN","pins":["J1.2","R1.1"]},{"name":"GND_ISO","pins":["J1.3","PWR2.1","U1.K"]},{"name":"N_ANODE","pins":["R1.2","U1.A"]},{"name":"VCC","pins":["PWR3.1","R2.1","C1.1","J2.1"]},{"name":"OUT_5V","pins":["U1.C","R2.2","J2.2"]},{"name":"GND","pins":["U1.E","PWR4.1","C1.2","J2.3"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"J1","x":10,"y":70},{"id":"PWR1","x":10,"y":20},{"id":"PWR2","x":10,"y":130},{"id":"R1","x":60,"y":70},{"id":"U1","x":120,"y":70},{"id":"PWR3","x":200,"y":10},{"id":"PWR4","x":200,"y":140},{"id":"R2","x":200,"y":50},{"id":"C1","x":240,"y":30},{"id":