{"metadata":{"title":"Momentary button MCU input with pull-up and series resistor","description":"Single momentary push-button interfaced to a microcontroller input on 5V: 10k pull-up to VCC keeps the line high, button pulls low to GND, 1k series resistor protects the MCU pin; 100nF bypass on the MCU supply.","version":"0.1","tags":["button","pull-up","debounce","mcu","input","5V"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"VCC1","type":"power_vcc","value":"5V","part":"PWR","pins":{"1":"VCC"}},{"id":"GND1","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}},{"id":"SW1","type":"button","value":"MOMENTARY","part":"6mm_tact","pins":{"1":"SW_OUT","2":"GND"}},{"id":"R1","type":"resistor","value":"10k","part":"0603","pins":{"1":"VCC","2":"SW_OUT"}},{"id":"R2","type":"resistor","value":"1k","part":"0603","pins":{"1":"SW_OUT","2":"MCU_IN"}},{"id":"U1","type":"ic_mcu","value":"ATTINY85","part":"SOIC-8","pins":{"VCC":"VCC","GND":"GND","IO1":"MCU_IN"}},{"id":"C1","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VCC","2":"GND"}}],"nets":[{"name":"VCC","pins":["VCC1.1","R1.1","U1.VCC","C1.1"]},{"name":"GND","pins":["GND1.1","SW1.2","U1.GND","C1.2"]},{"name":"SW_OUT","pins":["SW1.1","R1.2","R2.1"]},{"name":"MCU_IN","pins":["R2.2","U1.IO1"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"VCC1","x":20,"y":20},{"id":"GND1","x":20,"y":120},{"id":"R1","x":70,"y":40},{"id":"SW1","x":70,"y":100},{"id":"R2","x":130,"y":70},{"id":"U1","x":200,"y":60},{"id":"C1","x":250,"y":30}]}}