{"metadata":{"title":"Single GPIO level shifter between two boards","description":"Bidirectional level shifter translating one GPIO line between a 5V board and a 3.3V board, with bypass capacitors on both rails and headers to each board","version":"0.1","tags":["level-shifter","gpio","interface","3v3","5v"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"PWR1","type":"power_vcc","value":"5V","part":"PWR","pins":{"1":"VCC"}},{"id":"PWR2","type":"power_3v3","value":"3.3V","part":"PWR","pins":{"1":"VCC_3V3"}},{"id":"PWR3","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}},{"id":"U1","type":"ic_level_shifter","value":"TXS0101","part":"SOT-563","pins":{"VCC_A":"VCC","VCC_B":"VCC_3V3","GND":"GND","A":"GPIO_5V","B":"GPIO_3V3"}},{"id":"C1","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VCC","2":"GND"}},{"id":"C2","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VCC_3V3","2":"GND"}},{"id":"J1","type":"connector","value":"5V board GPIO","part":"HDR-1x2","pins":{"1":"GPIO_5V","2":"GND"}},{"id":"J2","type":"connector","value":"3.3V board GPIO","part":"HDR-1x2","pins":{"1":"GPIO_3V3","2":"GND"}}],"nets":[{"name":"VCC","pins":["PWR1.1","U1.VCC_A","C1.1"]},{"name":"VCC_3V3","pins":["PWR2.1","U1.VCC_B","C2.1"]},{"name":"GND","pins":["PWR3.1","U1.GND","C1.2","C2.2","J1.2","J2.2"]},{"name":"GPIO_5V","pins":["J1.1","U1.A"]},{"name":"GPIO_3V3","pins":["U1.B","J2.1"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"PWR1","x":40,"y":20},{"id":"PWR2","x":220,"y":20},{"id":"PWR3","x":130,"y":160},{"id":"U1","x":130,"y":80},{"id":"C1","x":80,"y":50},{"id":"C2","x":180,"y":50},{"id":"J1","x":20,"y":90},{"id":"J2","x":250,"y":90}]}}