{"metadata":{"title":"Passive RC treble-cut guitar tone control","description":"Classic passive guitar tone stack: a 500k audio-taper potentiometer wired as a rheostat in series with a 47nF capacitor, shunted from the signal line to ground. Turning the pot down rolls off treble harshness; the output jack taps the same signal node, fully passive with no power required.","version":"0.1","tags":["guitar","tone-control","passive","rc-filter","treble-cut","audio"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"J1","type":"connector","value":"GUITAR_IN","part":"JACK_6.35MM_MONO","pins":{"1":"SIG","2":"GND"}},{"id":"RV1","type":"potentiometer","value":"500k AUDIO","part":"POT_ALPHA_500KA","pins":{"A":"SIG","W":"N1","B":"N1"}},{"id":"C1","type":"capacitor","value":"47nF","part":"FILM_63V","pins":{"1":"N1","2":"GND"}},{"id":"J2","type":"connector","value":"AMP_OUT","part":"JACK_6.35MM_MONO","pins":{"1":"SIG","2":"GND"}},{"id":"PWR1","type":"power_vcc","value":"N/A","part":"PWR","pins":{"1":"VCC"}},{"id":"PWR2","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}}],"nets":[{"name":"SIG","pins":["J1.1","RV1.A","J2.1"]},{"name":"N1","pins":["RV1.W","RV1.B","C1.1"]},{"name":"GND","pins":["J1.2","C1.2","J2.2","PWR2.1"]},{"name":"VCC","pins":["PWR1.1"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"J1","x":20,"y":80},{"id":"RV1","x":110,"y":80},{"id":"C1","x":110,"y":140},{"id":"J2","x":210,"y":80},{"id":"PWR1","x":20,"y":20},{"id":"PWR2","x":110,"y":200}]}}