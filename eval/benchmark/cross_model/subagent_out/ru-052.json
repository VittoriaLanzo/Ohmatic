{"metadata":{"title":"Battery low warning beeper","description":"Comparator monitors battery voltage via divider against a precision reference; when the battery sags below threshold the open-drain output is pulled high and an NPN transistor drives a piezo beeper. Battery is fused for protection.","version":"0.1","tags":["battery","low-voltage","comparator","beeper","alarm"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"BT1","type":"battery","value":"3.7V Li-ion","part":"18650","pins":{"+":"VBAT","-":"GND"}},{"id":"F1","type":"fuse","value":"500mA","part":"polyfuse","pins":{"1":"VBAT","2":"VCC"}},{"id":"VCC1","type":"power_vcc","value":"3.7V","part":"PWR","pins":{"1":"VCC"}},{"id":"GND1","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}},{"id":"U2","type":"ic_voltage_ref","value":"2.5V","part":"TL431","pins":{"IN":"VCC","OUT":"VREF","GND":"GND"}},{"id":"C2","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VREF","2":"GND"}},{"id":"R1","type":"resistor","value":"100k","part":"0603","pins":{"1":"VCC","2":"VSENSE"}},{"id":"R2","type":"resistor","value":"220k","part":"0603","pins":{"1":"VSENSE","2":"GND"}},{"id":"U1","type":"ic_comparator","value":"LM393","part":"SOIC-8","pins":{"IN+":"VREF","IN-":"VSENSE","OUT":"COMP_OUT","VCC":"VCC","GND":"GND"}},{"id":"C1","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VCC","2":"GND"}},{"id":"C3","type":"capacitor","value":"100nF","part":"0603","pins":{"1":"VCC","2":"GND"}},{"id":"R3","type":"resistor","value":"10k","part":"0603","pins":{"1":"VCC","2":"COMP_OUT"}},{"id":"R4","type":"resistor","value":"4.7k","part":"0603","pins":{"1":"COMP_OUT","2":"BASE"}},{"id":"Q1","type":"transistor_npn","value":"2N3904","part":"SOT-23","pins":{"B":"BASE","C":"BUZZ","E":"GND"}},{"id":"SP1","type":"speaker","value":"piezo buzzer","part":"PKM13","pins":{"1":"VCC","2":"BUZZ"}}],"nets":[{"name":"VBAT","pins":["BT1.+","F1.1"]},{"name":"VCC","pins":["F1.2","VCC1.1","U2.IN","R1.1","U1.VCC","C1.1","C3.1","R3.1","SP1.1"]