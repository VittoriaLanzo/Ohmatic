{"metadata":{"title":"6V lead-acid solar charger","description":"Charges a 6V lead-acid battery from a small 9V (open-circuit) solar panel. Schottky blocking diode prevents night-time back-discharge, LM317 regulates the charge rail to ~7.0V float, a 3.3R series resistor limits charge current to ~0.3A, and a polyfuse protects the battery terminal.","version":"0.1","tags":["solar","charger","lead-acid","lm317","current-limit"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"J1","type":"connector","value":"SOLAR_9V","part":"TERM_2P","pins":{"1":"SOLAR_IN","2":"GND"}},{"id":"D1","type":"schottky_diode","value":"1N5819","part":"DO-41","pins":{"A":"SOLAR_IN","K":"VIN_RAIL"}},{"id":"C1","type":"capacitor","value":"100nF","part":"0805","pins":{"1":"VIN_RAIL","2":"GND"}},{"id":"U1","type":"ic_regulator","value":"LM317","part":"TO-220","pins":{"VIN":"VIN_RAIL","VOUT":"VCC","ADJ":"ADJ"}},{"id":"R1","type":"resistor","value":"240","part":"0805","pins":{"1":"VCC","2":"ADJ"}},{"id":"R2","type":"resistor","value":"1.1k","part":"0805","pins":{"1":"ADJ","2":"GND"}},{"id":"C2","type":"capacitor","value":"10uF","part":"ELEC_RADIAL","pins":{"1":"VCC","2":"GND"}},{"id":"R3","type":"resistor","value":"3.3 1W","part":"AXIAL_1W","pins":{"1":"VCC","2":"CHG"}},{"id":"F1","type":"fuse","value":"500mA","part":"POLYFUSE","pins":{"1":"CHG","2":"VBAT"}},{"id":"BT1","type":"battery","value":"6V_PB","part":"PACK","pins":{"+":"VBAT","-":"GND"}},{"id":"VCC1","type":"power_vcc","value":"7V","part":"PWR","pins":{"1":"VCC"}},{"id":"GND1","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}}],"nets":[{"name":"SOLAR_IN","pins":["J1.1","D1.A"]},{"name":"VIN_RAIL","pins":["D1.K","C1.1","U1.VIN"]},{"name":"VCC","pins":["U1.VOUT","R1.1","C2.1","R3.1","VCC1.1"]},{"name":"ADJ","pins":["U1.ADJ","R1.2","R2.1"]},{"name":"CHG","pins":["R3.2","F1.1"]},{"name":"VBAT","pins":["F1.2","BT1.+"]},{"name":"GND","pins":["J1.2","C1.2","R2.2","C2.2","BT1.-","GND1.1"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"J1","x":1