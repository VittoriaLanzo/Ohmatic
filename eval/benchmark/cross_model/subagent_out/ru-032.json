{"metadata":{"title":"Arduino relay driver","description":"NPN transistor relay driver switched from an Arduino GPIO via a 1k base resistor, with flyback diode across the relay coil and screw-terminal output for the switched load","version":"0.1","tags":["relay","arduino","driver","npn","flyback"]},"STAGE_1_TOPOLOGY":{"components":[{"id":"VCC1","type":"power_vcc","value":"5V","part":"PWR","pins":{"1":"VCC"}},{"id":"GND1","type":"power_gnd","value":"0V","part":"PWR","pins":{"1":"GND"}},{"id":"J1","type":"connector","value":"ARDUINO_HDR","part":"HDR-1x3","pins":{"1":"VCC","2":"GND","3":"CTRL"}},{"id":"R1","type":"resistor","value":"1k","part":"0603","pins":{"1":"CTRL","2":"BASE"}},{"id":"Q1","type":"transistor_npn","value":"2N2222","part":"SOT-23","pins":{"B":"BASE","C":"COIL_SW","E":"GND"}},{"id":"D1","type":"diode","value":"1N4007","part":"DO-41","pins":{"A":"COIL_SW","K":"VCC"}},{"id":"K1","type":"relay","value":"5V_SPDT","part":"SRD-05VDC","pins":{"A1":"VCC","A2":"COIL_SW","COM":"LOAD_COM","NO":"LOAD_NO"}},{"id":"J2","type":"connector","value":"LOAD_OUT","part":"TERM-1x2","pins":{"1":"LOAD_COM","2":"LOAD_NO"}}],"nets":[{"name":"VCC","pins":["VCC1.1","J1.1","D1.K","K1.A1"]},{"name":"GND","pins":["GND1.1","J1.2","Q1.E"]},{"name":"CTRL","pins":["J1.3","R1.1"]},{"name":"BASE","pins":["R1.2","Q1.B"]},{"name":"COIL_SW","pins":["K1.A2","Q1.C","D1.A"]},{"name":"LOAD_COM","pins":["K1.COM","J2.1"]},{"name":"LOAD_NO","pins":["K1.NO","J2.2"]}]},"STAGE_2_LAYOUT":{"spatial_nodes":[{"id":"VCC1","x":20,"y":20},{"id":"GND1","x":20,"y":160},{"id":"J1","x":20,"y":90},{"id":"R1","x":80,"y":90},{"id":"Q1","x":140,"y":110},{"id":"D1","x":170,"y":50},{"id":"K1","x":210,"y":60},{"id":"J2","x":270,"y":60}]}}