# Python
venv/
__pycache__/
*.py[cod]
.env

# Dataset / training data lives on HF (private), never in git
.dataset_cache/
dataset/prepared/
dataset/authored/
dataset/generated/

# Held-out benchmark data + derived fixtures (IP; scripts stay tracked)
eval/benchmark/*.jsonl
eval/benchmark/*.txt
eval/benchmark/holdout_manifest.json
eval/benchmark/reports/
eval/benchmark/cross_model/results/
eval/benchmark/cross_model/verified/
tests/fixtures/erc_golden.jsonl

# Node / frontend
node_modules/
frontend/dist/
frontend/*.log
frontend/*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
frontend/.env.local

# Internal-only dev tools (not part of the shipped build; kept out of the launch repo)
frontend/internal-tools/

# Rust
target/

# Launcher run-state (generated by `ohmatic start` on every machine)
.ohmatic-run/

# Runtime logs (any service)
*.log

# Local model weights (fetched by ./ohmatic fetch)
models/

# Local agent / editor state - never ship
.claude/
.vscode/
